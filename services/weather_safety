"""
Filename: services/weather_safety.py
Version: 0.5.4
"""
print("BOOTING Weather Safety Service...")

import json
import time
import os
import sys
from pathlib import Path

# Add project root to sys.path to find core and app
sys.path.append(os.getcwd())

try:
    from core.weather import WeatherMonitor
    from app import SeestarApp
    print("Imports successful.")
except ImportError as e:
    print(f"IMPORT ERROR: {e}")
    sys.exit(1)

def run_safety_monitor():
    try:
        app = SeestarApp()
        status_path = Path("logs/weather_status.json")
        print(f"Monitor active for {app.weather.location_name}. Writing to {status_path}")
        
        while True:
            safe, message = app.weather.is_safe()
            metrics = app.weather.get_metrics()
            
            status = {
                "last_check": time.strftime('%Y-%m-%d %H:%M:%S'),
                "safe": safe,
                "message": message,
                "metrics": metrics
            }
            
            with open(status_path, "w") as f:
                json.dump(status, f)
            
            print(f"Update: {time.strftime('%H:%M:%S')} - Safe: {safe}")
            time.sleep(300)
    except Exception as e:
        print(f"RUNTIME ERROR: {e}")

if __name__ == "__main__":
    run_safety_monitor()
